{
  "name": "@quicknode/x402",
  "version": "0.1.0",
  "description": "Quicknode x402 client — multi-chain payment, SIWX auth, session management",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/quiknode-labs/quicknode-x402.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@x402/core": "^2.3.1",
    "@x402/evm": "~2.2.0",
    "@x402/svm": "^2.3.0",
    "@x402/extensions": "^2.3.1",
    "viem": "^2.44.0",
    "@solana/signers": "^2.1.0",
    "@solana/codecs": "^2.1.0",
    "@connectrpc/connect": "^2.0.0",
    "@connectrpc/connect-web": "^2.0.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "tsup": "^8.5.0",
    "vitest": "^3.1.4",
    "@vitest/coverage-v8": "^3.1.4"
  }
}
